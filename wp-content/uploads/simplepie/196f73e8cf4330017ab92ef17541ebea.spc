			";s:7:"attribs";a:0:{}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";s:5:"child";a:1:{s:27:"http://www.w3.org/2005/Atom";a:1:{s:4:"name";a:1:{i:0;a:5:{s:4:"data";s:13:"Justine Calma";s:7:"attribs";a:0:{}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}}}}}}s:5:"title";a:1:{i:0;a:5:{s:4:"data";s:108:"European retailers yank popular headphones after study reports trace amounts of hormone-disrupting chemicals";s:7:"attribs";a:1:{s:0:"";a:1:{s:4:"type";s:4:"html";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}}s:4:"link";a:1:{i:0;a:5:{s:4:"data";s:0:"";s:7:"attribs";a:1:{s:0:"";a:3:{s:3:"rel";s:9:"alternate";s:4:"type";s:9:"text/html";s:4:"href";s:85:"https://www.theverge.com/science/894771/headphones-hormone-disrupting-chemicals-study";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}}s:2:"id";a:1:{i:0;a:5:{s:4:"data";s:34:"https://www.theverge.com/?p=894771";s:7:"attribs";a:0:{}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}}s:7:"updated";a:1:{i:0;a:5:{s:4:"data";s:25:"2026-03-13T21:16:32-04:00";s:7:"attribs";a:0:{}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}}s:9:"published";a:1:{i:0;a:5:{s:4:"data";s:25:"2026-03-14T07:00:00-04:00";s:7:"attribs";a:0:{}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}}s:8:"category";a:7:{i:0;a:5:{s:4:"data";s:0:"";s:7:"attribs";a:1:{s:0:"";a:2:{s:6:"scheme";s:24:"https://www.theverge.com";s:4:"term";s:8:"Analysis";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}i:1;a:5:{s:4:"data";s:0:"";s:7:"attribs";a:1:{s:0:"";a:2:{s:6:"scheme";s:24:"https://www.theverge.com";s:4:"term";s:11:"Environment";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}i:2;a:5:{s:4:"data";s:0:"";s:7:"attribs";a:1:{s:0:"";a:2:{s:6:"scheme";s:24:"https://www.theverge.com";s:4:"term";s:7:"Gadgets";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}i:3;a:5:{s:4:"data";s:0:"";s:7:"attribs";a:1:{s:0:"";a:2:{s:6:"scheme";s:24:"https://www.theverge.com";s:4:"term";s:10:"Headphones";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}i:4;a:5:{s:4:"data";s:0:"";s:7:"attribs";a:1:{s:0:"";a:2:{s:6:"scheme";s:24:"https://www.theverge.com";s:4:"term";s:6:"Health";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}i:5;a:5:{s:4:"data";s:0:"";s:7:"attribs";a:1:{s:0:"";a:2:{s:6:"scheme";s:24:"https://www.theverge.com";s:4:"term";s:6:"Report";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}i:6;a:5:{s:4:"data";s:0:"";s:7:"attribs";a:1:{s:0:"";a:2:{s:6:"scheme";s:24:"https://www.theverge.com";s:4:"term";s:7:"Science";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}}s:7:"summary";a:1:{i:0;a:5:{s:4:"data";s:403:"Some European retailers have stopped selling certain headphones after an EU-funded study found that they contained hormone-disrupting chemicals. The study included leading brands such as Apple, Beats, Samsung, Bose, JBL, and Sennheiser. Online stores Bol.com, Coolblue, and Mediamarkt didn't respond to inquiries from The Verge about which headphones they pulled, but local news outlets report [&#8230;]";s:7:"attribs";a:1:{s:0:"";a:1:{s:4:"type";s:4:"html";}}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:5:"en-US";}}s:7:"content";a:1:{i:0;a:5:{s:4:"data";s:1648:"
											

						
<figure>

<img alt="Rows of blue headphones floating diagonally against a pink background." data-caption="" data-portal-copyright="Image: The Verge" data-has-syndication-rights="1" src="https://platform.theverge.com/wp-content/uploads/sites/2/chorus/uploads/chorus_asset/file/24492430/STK459_Music_Headphones.jpg?quality=90&#038;strip=all&#038;crop=0,0,100,100" />
	<figcaption>
		</figcaption>
</figure>
<p class="has-text-align-none">Some European retailers have stopped selling certain headphones after an EU-funded <a href="https://arnika.org/en/news/the-sound-of-contamination-all-analysed-headphones-on-the-central-european-market-found-to-contain-hormone-disrupting-chemicals">study</a> found that they contained hormone-disrupting chemicals. </p>
<p class="has-text-align-none">The study included leading brands such as Apple, Beats, Samsung, Bose, JBL, and Sennheiser. Online stores Bol.com, Coolblue, and Mediamarkt didn't respond to inquiries from <em>The Verge </em>about which headphones they pulled, but local <a href="https://www.rtl.nl/nieuws/economie/artikel/5570754/giftige-stoffen-koptelefoons-en-oordopjes-hema-bol-en-mediamarkt">news outlets report</a> that they're among the retailers that have decided to yank some of the worst-scoring models off the market.  </p>
<p class="has-text-align-none">The study authors analyzed 81 different types of headphones, and found that all of them contained at least traces of harmful chemicals includi …</p>
<p><a href="https://www.theverge.com/science/894771/headphones-hormone-disrupting-chemicals-study">Read the full story at The Verge.</a></p>
						
