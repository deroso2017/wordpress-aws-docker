	1	";s:7:"attribs";a:0:{}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:0:"";}}}s:30:"com-wordpress:feed-additions:1";a:1:{s:4:"site";a:1:{i:0;a:5:{s:4:"data";s:7:"9006382";s:7:"attribs";a:0:{}s:8:"xml_base";s:0:"";s:17:"xml_base_explicit";b:0;s:8:"xml_lang";s:0:"";}}}}}}}}}}}}s:4:"type";i:128;s:7:"headers";a:15:{s:6:"server";s:5:"nginx";s:4:"date";s:29:"Sat, 14 Mar 2026 15:35:20 GMT";s:12:"content-type";s:34:"application/rss+xml; charset=UTF-8";s:25:"strict-transport-security";s:16:"max-age=31536000";s:4:"vary";s:45:"Accept-Encoding, accept, content-type, cookie";s:11:"host-header";s:7:"wpcloud";s:13:"last-modified";s:29:"Wed, 11 Mar 2026 14:00:00 GMT";s:4:"etag";s:36:"W/"3717cb4be0b3285214fd647c22ad52a8"";s:4:"link";s:57:"<https://wptavern.com/wp-json/>; rel="https://api.w.org/"";s:13:"cache-control";s:28:"max-age=300, must-revalidate";s:10:"x-nananana";s:12:"Batcache-Set";s:16:"content-encoding";s:4:"gzip";s:4:"x-ac";s:23:"3.ams _atomic_ams STALE";s:7:"alt-svc";s:19:"h3=":443"; ma=86400";s:13:"server-timing";s:46:"a8c-cdn, dc;desc=ams, cache;desc=STALE;dur=2.0";}s:5:"build";i:1760643936;s:21:"cache_expiration_time";i:1773506122;s:23:"__cache_expiration_time";i:1773506122;}